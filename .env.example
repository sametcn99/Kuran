# =============================================================================
# DİYANET KUR'AN-I KERİM WEB UYGULAMASI - ORTAM DEĞİŞKENLERİ
# =============================================================================
# Bu dosyayı kopyalayarak .env.local dosyası oluşturun:
#   cp .env.example .env.local
# Ardından .env.local dosyasındaki değerleri gerçek bilgilerinizle güncelleyin.
# =============================================================================

# -----------------------------------------------------------------------------
# API AYARLARI
# -----------------------------------------------------------------------------
# Diyanet İşleri Başkanlığı'nın resmi Kuran API'sine bağlanmak için gerekli ayarlar.
#
# DIB_KURAN_API_BASE_URL: Diyanet Kuran API'sinin temel (base) adresi.
#   - Varsayılan olarak Diyanet'in resmi API adresi kullanılır.
#   - Geliştirme ortamında farklı bir endpoint kullanıyorsanız burayı güncelleyin.
#   -  Not: Aşağıdaki url adresine erişim sağlanamazsa https://acikkaynakkuran-dev.diyanet.gov.tr 
#     adresindeki dökümantasyon ve destek kanallarını kontrol edebilirsiniz.
DIB_KURAN_API_BASE_URL=https://api.diyanet.gov.tr

# DIB_KURAN_API_TOKEN: Diyanet Kuran API'sine erişim için gerekli kimlik doğrulama token'ı.
#   - API token'ı almak için community@diyanet.gov.tr adresine başvuruda bulunabilirsiniz.
#   - Ayrıca https://acikkaynakkuran-dev.diyanet.gov.tr adresinden bilgi alabilirsiniz.
#   - GitHub [@diyanet-bid](https://github.com/diyanet-bid) sayfasını takip edebilirsiniz.
#   - ÖNEMLİ: Gerçek token değerinizi asla bu dosyaya yazmayın, sadece .env.local dosyasında kullanın.
DIB_KURAN_API_TOKEN=your_actual_api_token_here

# -----------------------------------------------------------------------------
# TEMEL UYGULAMA AYARLARI (HENÜZ ALTYAPI HAZIR DEĞİL)
# -----------------------------------------------------------------------------
# Aşağıdaki ayarlar gelecekte kullanılmak üzere planlanmıştır.
# Şu an uygulama tarafından okunmamaktadır, ancak altyapı hazır olduğunda aktif edilecektir.
# Yorum satırını kaldırarak (# işaretini silerek) bu değerleri aktif edebilirsiniz.

# FRONTEND_APP_PORT: Uygulamanın çalışacağı port numarası.
#   - Varsayılan değer: 3000
#   - Port çakışması durumunda farklı bir port (ör. 3001) belirtebilirsiniz.
#   - Alternatif olarak: npm run dev -- --port 3001 şeklinde de kullanılabilir.
# FRONTEND_APP_PORT=3000

# FRONTEND_APP_URL: Uygulamanın tam erişim adresi.
#   - FRONTEND_APP_PORT değişkenini referans alarak otomatik oluşturulur.
#   - Yerel geliştirme için http://localhost formatındadır.
# FRONTEND_APP_URL="http://localhost:${FRONTEND_APP_PORT}"

# FRONTEND_APP_NAME: Uygulamanın görünen adı.
#   - Tarayıcı sekmesinde ve meta etiketlerinde kullanılır.
# FRONTEND_APP_NAME="Kuran-ı Kerim Dijital Diyanet Projesi"